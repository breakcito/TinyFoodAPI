model usuario {
  id                   Int       @id @default(autoincrement())
  id_supabase          String    @unique @db.Uuid
  nombre               String
  url_foto             String? // apunta a la url de google o del bucket de supabase
  fecha_nacimiento     DateTime? @db.Date // se guarda como: año - mes - dia
  genero               String // 'masculino', 'femenino', 'otro'
  //
  peso                 Decimal?  @db.Decimal // en kg
  talla                Decimal?  @db.Decimal // en centimetros
  //
  nivel_actividad      Int?      @default(1) // el 1 al 5
  informacion_medica   Json? // [{"nombre": "", "descripcion": ""},...]
  configuracion        Json?     @default("{}") // preferencias de cocina e IA
  //
  alimentos_prohibidos String[] // ['platano', 'nuez', ...]
  preferencias         String[] // ['pollo frito', 'torta de chotolatep', ...]
  objetivo_fisico      String?   // 'mantener', 'perder peso', 'ganar peso', ...
  //
  created_at           DateTime  @default(now()) @db.Timestamptz
  // Relaciones
  // 1 - N
  comidas              comida[]
}
